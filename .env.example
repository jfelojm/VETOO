# ============================================================
# BARBERAPP — Variables de entorno
# Copia este archivo como .env.local y rellena los valores
# NUNCA subas .env.local a GitHub
# ============================================================

# --- SUPABASE ---
# Los encuentras en: supabase.com > tu proyecto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- STRIPE ---
# Los encuentras en: dashboard.stripe.com > Developers > API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs de los productos en Stripe (los creas tú en el dashboard)
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# --- RESEND (emails) ---
# Lo encuentras en: resend.com > API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=reservas@tudominio.com

# --- APP ---
# Producción: https://tu-dominio.vercel.app (sin barra final).
# En Supabase > Auth > URL: añade a "Redirect URLs":
#   {NEXT_PUBLIC_APP_URL}/auth/confirm
#   {NEXT_PUBLIC_APP_URL}/api/auth/callback
NEXT_PUBLIC_APP_URL=http://localhost:3000
